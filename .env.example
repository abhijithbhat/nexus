# ── LLM ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ── Twilio WhatsApp ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
USER_WHATSAPP_NUMBER=whatsapp:+91XXXXXXXXXX

# ── Google APIs (Gmail + Calendar) ───────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# ── Database Paths ────────────────────────────────────────────────────
SQLITE_DB_PATH=./data/nexus.db
CHROMA_DB_PATH=./data/chroma_store

# ── App Configuration ─────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
ADMIN_SECRET_KEY=your_random_secret_key_here

# ── User Profile (seed into memory on first run) ─────────────────────
USER_NAME=your_name_here
USER_INTERESTS=your_interests_comma_separated
USER_GOALS=your_goals_comma_separated
USER_LOCATION=your_city_country_here

# ── Scheduler Timing (24h format, IST) ───────────────────────────────
MORNING_BRIEF_TIME=08:00
REFLECTION_TIME=23:30
MONITOR_INTERVAL_HOURS=6
DEADLINE_CHECK_INTERVAL_HOURS=4
MEMORY_CONSOLIDATION_DAY=sunday
