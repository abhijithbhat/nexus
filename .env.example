# ═══════════════════════════════════════════════════════════════════════
# NEXUS .env — NEVER COMMIT TO GIT
# Regenerate all keys after initial setup at:
#   Gemini  → https://aistudio.google.com/app/apikey
#   Twilio  → https://console.twilio.com
#   Google  → https://console.cloud.google.com/apis/credentials
# ═══════════════════════════════════════════════════════════════════════

# ── LLM ──────────────────────────────────────────────────────────────
# NOTE: Real Gemini API keys start with "AIza". Verify at aistudio.google.com.
GEMINI_API_KEY=

# ── Twilio WhatsApp ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
USER_WHATSAPP_NUMBER=

# ── Google APIs (Gmail + Calendar — Phase 5+) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Database Paths ────────────────────────────────────────────────────
SQLITE_DB_PATH=
CHROMA_DB_PATH=

# ── App Config ────────────────────────────────────────────────────────
APP_ENV=
LOG_LEVEL=
ADMIN_SECRET_KEY=

# ── User Profile (seeded into memory on first run) ───────────────────
USER_NAME=
USER_INTERESTS=
USER_GOALS=
USER_LOCATION=

# ── Scheduler Timing (24h format, IST) ───────────────────────────────
MORNING_BRIEF_TIME=
REFLECTION_TIME=
MONITOR_INTERVAL_HOURS=
DEADLINE_CHECK_INTERVAL_HOURS=
SEND_REFLECTION_SUMMARY=
